{
  "brand": {
    "name": "GraphitePDF",
    "tagline": "PDF generation for Rust",
    "voice": [
      "precise",
      "industrial",
      "trustworthy",
      "systems-oriented",
      "modern open source"
    ]
  },
  "typography": {
    "wordmark": {
      "family": "Space Grotesk",
      "fallback": "Space Grotesk, Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif"
    },
    "ui": {
      "family": "Space Grotesk, Inter, ui-sans-serif, system-ui, -apple-system, Segoe UI, sans-serif"
    },
    "code": {
      "family": "JetBrains Mono, SFMono-Regular, Menlo, Monaco, Consolas, Liberation Mono, monospace"
    }
  },
  "colors": {
    "primary": {
      "graphite950": "#060604",
      "graphite900": "#1E1E1C",
      "graphite850": "#2E2E2C",
      "graphite700": "#3A3A38",
      "graphite600": "#606060",
      "graphite500": "#6E6E6C",
      "mist300": "#C4C4C0"
    },
    "secondary": {
      "steel400": "#585856",
      "steel500": "#666664",
      "alloy500": "#6A6A68",
      "lightPanel": "#F3F2EE",
      "lightPanelAlt": "#E7E4DD"
    },
    "accent": {
      "rustGlow400": "#F58040",
      "rustEmber500": "#D4581A",
      "rustEmber600": "#C84C14",
      "rustOxide700": "#7C2806"
    },
    "effects": {
      "slateGlow": "rgba(255,255,255,0.18)",
      "subtleDividerOnDark": "rgba(255,255,255,0.10)",
      "shadowInk": "rgba(0,0,0,0.45)"
    }
  },
  "gradients": {
    "graphiteSurface": "linear-gradient(135deg, #3A3A38 0%, #6E6E6C 42%, #3A3A38 100%)",
    "rustCore": "radial-gradient(circle at 36% 30%, #F58040 0%, #C84C14 50%, #7C2806 100%)"
  },
  "ui": {
    "background": {
      "darkBase": "#111110",
      "darkRaised": "#1E1E1C",
      "surface": "#2E2E2C",
      "surfaceElevated": "#3A3A38"
    },
    "text": {
      "onLight": "#1E1E1C",
      "onDark": "#C4C4C0",
      "secondary": "#6E6E6C",
      "accent": "#D4581A"
    },
    "border": {
      "strong": "#3A3A38",
      "standard": "#585856",
      "subtleOnDark": "rgba(255,255,255,0.10)"
    },
    "interactive": {
      "default": "#D4581A",
      "hover": "#F58040",
      "active": "#C84C14",
      "disabled": "#666664"
    }
  }
}
